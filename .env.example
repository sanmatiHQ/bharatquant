# BharatQuant — copy to .env on VM (production: GCP Secret Manager)
TZ=Asia/Kolkata

# Zerodha Kite Connect — https://developers.kite.trade/
KITE_API_KEY=
KITE_API_SECRET=
KITE_REDIRECT_URL=https://YOUR_VM_IP:8080/kite/callback
KITE_ACCESS_TOKEN_FILE=/var/lib/bharatquant/.kite_token.json

# Headless auth (100% autonomous)
KITE_USER_ID=
KITE_PASSWORD=
KITE_TOTP_SECRET=

# Trading
TRADING_MODE=paper
DAILY_INVESTMENT_MIN=500
DAILY_INVESTMENT_MAX=1000
MAX_POSITIONS=8
MAX_RUPEES_PER_TRADE=1000
MAX_DAILY_LOSS_RUPEES=2000
STOP_LOSS_PCT=4
TAKE_PROFIT_PCT=2.0
TRAILING_STOP_PCT=1.5
MAX_HOLD_MINUTES=240
SLIPPAGE_BPS=4
SQLITE_PATH=/var/lib/bharatquant/trading.db
UNIVERSE=data/universe_full_nse.csv
UNIVERSE_TIER=main
WS_WATCHLIST_SIZE=200
LOGS_DIR=/var/log/bharatquant

# Optional LLM (news only — not execution)
LLM_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
LLM_MAX_CALLS_PER_DAY=50

# Alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# GCP
GCP_PROJECT_ID=
GCP_STATIC_IP=
GCS_BACKUP_BUCKET=
SUPERVISOR_USE_SYSTEMD=true

# Market supervisor — arms engine on GIFT/NSE (not trading cron)
# Run: bash src/ops/start_system.sh  OR  python3.11 -m src.ops.market_supervisor
PAPER_ALWAYS_ON=true
SUPERVISOR_POLL_SEC=30

# RL / PPO
RL_ACTIVE_VERSION=ppo_v1
RL_MODEL_DIR=models/rl
RL_OBSERVER_ENABLED=true
RL_AGENT_ENABLED=true
RL_TRAIN_ON_CLOSE=true
RL_TRAIN_ON_TRADE=true
RL_MIN_TRANSITIONS_VETO=80
RL_DRAWDOWN_PENALTY=0.5

# Kill switch (set on VM; dashboard POST /internal/halt)
HALT_API_SECRET=

# Paper mode starting cash
PAPER_STARTING_CASH=10000
PORT=8080
SECTOR_MAP_CSV=data/sector_map.csv
STCG_TAX_RATE=0.125
LTCG_TAX_RATE=0.125
SHADOW_MODE=false
MAX_SECTOR_PCT=40
VAR_LIMIT_PCT=3
