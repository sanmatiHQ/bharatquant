# BharatQuant — copy to .env on VM (production: GCP Secret Manager)
TZ=Asia/Kolkata

# Zerodha Kite Connect — https://developers.kite.trade/
KITE_API_KEY=
KITE_API_SECRET=
KITE_REDIRECT_URL=https://YOUR_VM_IP:8080/kite/callback
KITE_ACCESS_TOKEN_FILE=/var/lib/bharatquant/.kite_token.json

# Headless auth (100% autonomous)
KITE_USER_ID=
KITE_PASSWORD=
KITE_TOTP_SECRET=

# Trading
TRADING_MODE=paper
DAILY_INVESTMENT_MIN=1500
DAILY_INVESTMENT_MAX=2000
BUDGET_APPROVAL_TIMEOUT_SEC=900
LIVE_GATE_MIN_PAPER_RETURN_PCT=5
LIVE_GATE_MIN_TRADE_COUNT=20
MAX_POSITIONS=8
MAX_RUPEES_PER_TRADE=2000
MAX_DAILY_LOSS_RUPEES=2000
STOP_LOSS_PCT=2.5
TAKE_PROFIT_PCT=4.0
TRAILING_STOP_PCT=1.2
MAX_HOLD_MINUTES=240
SLIPPAGE_BPS=4
SQLITE_PATH=/var/lib/bharatquant/trading.db
UNIVERSE=data/universe_full_nse.csv
OPTIONS_PAPER_ENABLED=true
UNIVERSE_TIER=with_sme
WS_WATCHLIST_SIZE=200
LOGS_DIR=/var/log/bharatquant

# Optional LLM (news only — not execution)
LLM_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
LLM_MAX_CALLS_PER_DAY=50

# Alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# GCP
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-south1
GCP_ZONE=asia-south1-a
VM_NAME=bharatquant-engine
GCP_STATIC_IP=
GCS_BACKUP_BUCKET=your-gcp-project-id-bharatquant
BHARATQUANT_PUBLIC_HOST=
SUPERVISOR_USE_SYSTEMD=false

# Market supervisor — arms engine on GIFT/NSE (not trading cron)
# Run: bash src/ops/start_system.sh  OR  python3.11 -m src.ops.market_supervisor
# macOS auto-start: bash scripts/install_launch_agent.sh
ENGINE_24X7=true
PAPER_ALWAYS_ON=true
SUPERVISOR_POLL_SEC=30
ENGINE_HEARTBEAT_MAX_SEC=90

# RL / PPO
RL_ACTIVE_VERSION=ppo_v1
RL_MODEL_DIR=models/rl
RL_OBSERVER_ENABLED=true
RL_AGENT_ENABLED=true
RL_TRAIN_ON_CLOSE=true
RL_TRAIN_ON_TRADE=true
RL_MIN_TRANSITIONS_VETO=80
RL_DRAWDOWN_PENALTY=0.5

# Kill switch (set on VM; dashboard POST /internal/halt)
HALT_API_SECRET=

# Paper mode starting cash
PAPER_STARTING_CASH=5000
PORT=8080

# Dashboard — public read-only; owner login for actions
DASHBOARD_ADMIN_USER=owner
DASHBOARD_ADMIN_PASSWORD=change-me-strong-password
DASHBOARD_SESSION_SECRET=
SECTOR_MAP_CSV=data/sector_map.csv
STCG_TAX_RATE=0.125
LTCG_TAX_RATE=0.125
SHADOW_MODE=false
MAX_SECTOR_PCT=40
VAR_LIMIT_PCT=3
