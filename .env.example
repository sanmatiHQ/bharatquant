# BharatQuant — copy to .env (never commit .env)
# Full reference: deploy/bharatquant.env.production (placeholders only in git)
TZ=Asia/Kolkata

# ── Zerodha Kite Connect — https://developers.kite.trade/ ──
KITE_API_KEY=
KITE_API_SECRET=
KITE_REDIRECT_URL=https://YOUR_PUBLIC_HOST/kite/callback
KITE_ACCESS_TOKEN_FILE=.kite_token.json
KITE_USER_ID=
KITE_PASSWORD=
KITE_TOTP_SECRET=

# ── Trading mode & gates ──
TRADING_MODE=paper
TRADING_PHASE=paper_learn
DAILY_INVESTMENT_MIN=1500
DAILY_INVESTMENT_MAX=2000
BUDGET_APPROVAL_TIMEOUT_SEC=900
BUDGET_ROLLOVER_MODE=accumulate
BUDGET_PACE=patient
LIVE_GATE_MIN_PAPER_RETURN_PCT=5
LIVE_GATE_MIN_TRADE_COUNT=20
LIVE_GATE_LOOKBACK_DAYS=30
MAX_POSITIONS=8
MAX_RUPEES_PER_TRADE=2000
MAX_DAILY_LOSS_RUPEES=2000
MAX_INTRADAY_DRAWDOWN_PCT=10
STOP_LOSS_PCT=4
TAKE_PROFIT_PCT=2.0
TRAILING_STOP_PCT=1.5
MAX_HOLD_MINUTES=240
SLIPPAGE_BPS=4
MIS_SQUAREOFF_HOUR=15.167
MIN_ORDER_INTERVAL_SEC=30
COST_MAX_ROUNDTRIP_PCT=3.5
SHADOW_MODE=false
MAX_SECTOR_PCT=40
VAR_LIMIT_PCT=3
OPTIONS_PAPER_ENABLED=true

# ── Paths & universe ──
SQLITE_PATH=data/trading.db
UNIVERSE=data/universe_full_nse.csv
UNIVERSE_TIER=main
SECTOR_MAP_CSV=data/sector_map.csv
WS_WATCHLIST_SIZE=400
LOGS_DIR=logs
ENGINE_PID_FILE=logs/engine.pid
DASH_PID_FILE=logs/dashboard.pid
PORT=8080
PAPER_STARTING_CASH=10000

# ── Engine / supervisor ──
ENGINE_24X7=true
PAPER_ALWAYS_ON=true
SUPERVISOR_USE_SYSTEMD=false
SUPERVISOR_POLL_SEC=30
ENGINE_HEARTBEAT_MAX_SEC=90
FAST_PATH_ENTRIES=true
FAST_DECISION_SEC=8
SCREEN_PARALLEL_WORKERS=10
EOD_SCAN_WORKERS=12
EOD_SCAN_TOP_N=200
BATCH_LTP_INTERVAL_SEC=12
BATCH_LTP_SIZE=200
FAST_SNAPSHOT_CANDIDATES=80
FEED_STALE_SEC=5
TELEMETRY_LATENCY_WARN_MS=400
RECONCILE_INTERVAL_SEC=300
RECONCILE_AUTO_REPAIR=true
MARGIN_MONITOR_SEC=60
MARGIN_UTIL_HALT_PCT=85
BROKER_SL_ENABLED=true
KITE_DEPTH_MODE=true
ATR_SIZING_ENABLED=true
ASYNC_LOGGING=true

# ── RL / PPO ──
RL_ACTIVE_VERSION=ppo_v1
RL_MODEL_DIR=models/rl
RL_OBSERVER_ENABLED=true
RL_AGENT_ENABLED=true
RL_TRAIN_ON_CLOSE=true
RL_TRAIN_ON_TRADE=true
RL_USE_GUARDRAILS=true
RL_USE_SB3=true
RL_LEARNING_RATE=1e-5
RL_TRAIN_EPOCHS=2
RL_SB3_TIMESTEPS=2000
RL_MAX_TRANSITIONS_PER_TRAIN=800
RL_ABNORMAL_DAY_PCT=3.0
RL_ABNORMAL_LR_SCALE=0.3
RL_ABNORMAL_TIMESTEPS_SCALE=0.25
RL_SHADOW_LOOKBACK_DAYS=30
RL_SHADOW_MAX_SYMBOLS=12
RL_SHADOW_MAX_REGRESSION_PCT=2.0
RL_MIN_TRANSITIONS_VETO=80
RL_DRAWDOWN_PENALTY=0.5
RL_PRIMARY_MODE=true
RL_PRIMARY_MIN_TRANSITIONS=200
REGIME_WEIGHTS_ENABLED=true
TICK_RING_CAPACITY=100
RL_HOLD_DECAY_PER_MIN=0.00015
RL_LOSS_HOLD_PENALTY=0.002
POSTMARKET_RL_DEFER=true
PREMARKET_ROUTINE_TIME=8:45
POSTMARKET_ROUTINE_TIME=16:15
VIX_BUDGET_AUTO_APPROVE_MAX=22
LLM_BEARISH_VETO=-0.5

# ── Limit chase (live mode only) ──
LIMIT_CHASE_ENABLED=false
LIMIT_CHASE_ATTEMPTS=3
LIMIT_CHASE_WAIT_SEC=1.5

# ── LLM (macro bias only — never on order path) ──
LLM_ENABLED=false
VERTEX_GEMINI_ENABLED=false
GCP_PROJECT=your-gcp-project-id
VERTEX_LOCATION=us-central1
VERTEX_GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
LLM_MACRO_INTERVAL_SEC=3600
LLM_MAX_CALLS_PER_DAY=50

# ── Tax rates (paper accounting) ──
STCG_TAX_RATE=0.125
LTCG_TAX_RATE=0.125

# ── Dashboard (public read-only; owner login for actions) ──
DASHBOARD_ADMIN_USER=owner
DASHBOARD_ADMIN_PASSWORD=change-me-strong-password
DASHBOARD_SESSION_SECRET=generate-a-long-random-string

# ── Kill switch (optional; dashboard /internal/halt) ──
HALT_API_SECRET=

# ── Alerts (optional) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── GCP deploy (optional — scripts/gcp_deploy.sh) ──
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-south1
GCP_ZONE=asia-south1-a
VM_NAME=bharatquant-engine
GCP_STATIC_IP=
GCS_BACKUP_BUCKET=your-gcp-project-id-bharatquant
BHARATQUANT_PUBLIC_HOST=
