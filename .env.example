# BharatQuant — copy to .env on VM (production: GCP Secret Manager)
TZ=Asia/Kolkata

# Zerodha Kite Connect — https://developers.kite.trade/
KITE_API_KEY=
KITE_API_SECRET=
KITE_REDIRECT_URL=https://YOUR_VM_IP:8080/kite/callback
KITE_ACCESS_TOKEN_FILE=/var/lib/bharatquant/.kite_token.json

# Headless auth (100% autonomous)
KITE_USER_ID=
KITE_PASSWORD=
KITE_TOTP_SECRET=

# Trading
TRADING_MODE=paper
DAILY_INVESTMENT_MIN=500
DAILY_INVESTMENT_MAX=1000
MAX_POSITIONS=5
MAX_RUPEES_PER_TRADE=1000
MAX_DAILY_LOSS_RUPEES=2000
SLIPPAGE_BPS=4
SQLITE_PATH=/var/lib/bharatquant/trading.db
UNIVERSE=data/universe_full_nse.csv
UNIVERSE_TIER=main
WS_WATCHLIST_SIZE=200
LOGS_DIR=/var/log/bharatquant

# Optional LLM (news only — not execution)
LLM_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
LLM_MAX_CALLS_PER_DAY=50

# Alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# GCP
GCP_PROJECT_ID=
GCP_STATIC_IP=
GCS_BACKUP_BUCKET=

# Kill switch (set on VM; dashboard POST /internal/halt)
HALT_API_SECRET=

# Paper mode starting cash
PAPER_STARTING_CASH=10000
PORT=8080
SECTOR_MAP_CSV=data/sector_map.csv
STCG_TAX_RATE=0.125
LTCG_TAX_RATE=0.125
SHADOW_MODE=false
MAX_SECTOR_PCT=40
VAR_LIMIT_PCT=3
