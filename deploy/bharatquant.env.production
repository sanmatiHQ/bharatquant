# BharatQuant production env — /etc/bharatquant/env on GCE VM
# Secrets synced by: bash scripts/gcp_sync_secrets.sh
TZ=Asia/Kolkata

GCP_PROJECT_ID=__GCP_PROJECT_ID__
GCP_STATIC_IP=__GCP_STATIC_IP__
GCS_BACKUP_BUCKET=__GCS_BACKUP_BUCKET__

# Zerodha Kite Connect — secrets injected by gcp_sync_secrets.sh
KITE_API_KEY=__KITE_API_KEY__
KITE_API_SECRET=__KITE_API_SECRET__
KITE_REDIRECT_URL=http://__GCP_STATIC_IP__:8080/kite/callback
KITE_ACCESS_TOKEN_FILE=/var/lib/bharatquant/.kite_token.json
KITE_USER_ID=__KITE_USER_ID__
KITE_PASSWORD=__KITE_PASSWORD__
KITE_TOTP_SECRET=__KITE_TOTP_SECRET__

# Trading — paper on VM until live gate
TRADING_MODE=paper
DAILY_INVESTMENT_MIN=500
DAILY_INVESTMENT_MAX=1000
MAX_POSITIONS=8
MAX_RUPEES_PER_TRADE=1000
MAX_DAILY_LOSS_RUPEES=2000
STOP_LOSS_PCT=4
TAKE_PROFIT_PCT=2.0
TRAILING_STOP_PCT=1.5
MAX_HOLD_MINUTES=240
SLIPPAGE_BPS=4
SQLITE_PATH=/var/lib/bharatquant/trading.db
UNIVERSE=data/universe_full_nse.csv
UNIVERSE_TIER=main
WS_WATCHLIST_SIZE=200
LOGS_DIR=/var/log/bharatquant
PORT=8080
PAPER_STARTING_CASH=10000
SECTOR_MAP_CSV=data/sector_map.csv

# GCP VM — supervisor manages engine via subprocess (not nested systemd children)
SUPERVISOR_USE_SYSTEMD=false
PAPER_ALWAYS_ON=true
SUPERVISOR_POLL_SEC=30

# RL
RL_ACTIVE_VERSION=ppo_v1
RL_MODEL_DIR=/var/lib/bharatquant/models/rl
RL_OBSERVER_ENABLED=true
RL_AGENT_ENABLED=true
RL_TRAIN_ON_CLOSE=true
RL_TRAIN_ON_TRADE=true
RL_MIN_TRANSITIONS_VETO=80
RL_DRAWDOWN_PENALTY=0.5

SHADOW_MODE=false
MAX_SECTOR_PCT=40
VAR_LIMIT_PCT=3
LLM_ENABLED=false
