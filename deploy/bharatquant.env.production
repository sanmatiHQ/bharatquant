# BharatQuant production env — /etc/bharatquant/env on GCE VM
# Secrets synced by: bash scripts/gcp_sync_secrets.sh
TZ=Asia/Kolkata

GCP_PROJECT_ID=__GCP_PROJECT_ID__
GCP_STATIC_IP=__GCP_STATIC_IP__
GCS_BACKUP_BUCKET=__GCS_BACKUP_BUCKET__
# Public HTTPS host (sslip.io — resolves to GCP_STATIC_IP; required by Kite redirect)
BHARATQUANT_PUBLIC_HOST=__BHARATQUANT_PUBLIC_HOST__

# Zerodha Kite Connect — secrets injected by gcp_sync_secrets.sh
KITE_API_KEY=__KITE_API_KEY__
KITE_API_SECRET=__KITE_API_SECRET__
KITE_REDIRECT_URL=https://__BHARATQUANT_PUBLIC_HOST__/kite/callback
KITE_ACCESS_TOKEN_FILE=/var/lib/bharatquant/.kite_token.json
KITE_USER_ID=__KITE_USER_ID__
KITE_PASSWORD=__KITE_PASSWORD__
KITE_TOTP_SECRET=__KITE_TOTP_SECRET__

# Trading — paper learn on real data; live ₹1500–2000/day after profitability gate
TRADING_MODE=paper
TRADING_PHASE=paper_learn
DAILY_INVESTMENT_MIN=1500
DAILY_INVESTMENT_MAX=2000
BUDGET_APPROVAL_TIMEOUT_SEC=900
LIVE_GATE_MIN_PAPER_RETURN_PCT=5
LIVE_GATE_MIN_TRADE_COUNT=20
LIVE_GATE_LOOKBACK_DAYS=30
MAX_POSITIONS=8
MAX_RUPEES_PER_TRADE=2000
MAX_DAILY_LOSS_RUPEES=2000
STOP_LOSS_PCT=4
TAKE_PROFIT_PCT=2.0
TRAILING_STOP_PCT=1.5
MAX_HOLD_MINUTES=240
SLIPPAGE_BPS=4
SQLITE_PATH=/var/lib/bharatquant/trading.db
UNIVERSE=data/universe_full_nse.csv
UNIVERSE_TIER=main
WS_WATCHLIST_SIZE=400
LOGS_DIR=/var/log/bharatquant
ENGINE_PID_FILE=/var/log/bharatquant/engine.pid
DASH_PID_FILE=/var/log/bharatquant/dashboard.pid
PORT=8080

# Dashboard auth — public read-only; owner login for actions
DASHBOARD_ADMIN_USER=owner
DASHBOARD_ADMIN_PASSWORD=__DASHBOARD_ADMIN_PASSWORD__
DASHBOARD_SESSION_SECRET=__DASHBOARD_SESSION_SECRET__

PAPER_STARTING_CASH=10000
SECTOR_MAP_CSV=data/sector_map.csv

# GCP VM — supervisor manages engine via subprocess (not nested systemd children)
SUPERVISOR_USE_SYSTEMD=false
ENGINE_24X7=true
PAPER_ALWAYS_ON=true
# Holistic decisions every 8s from screening+FII+GIFT+intraday move (not 31 strategies per tick)
FAST_PATH_ENTRIES=true
FAST_DECISION_SEC=8
# strict = spend today's ₹2000 today or lose it | accumulate = pool stacks (+₹2000 each open)
BUDGET_ROLLOVER_MODE=accumulate
# Full NSE screen parallelism + realtime LTP batches
SCREEN_PARALLEL_WORKERS=10
EOD_SCAN_WORKERS=12
EOD_SCAN_TOP_N=200
BATCH_LTP_INTERVAL_SEC=12
BATCH_LTP_SIZE=200
FAST_SNAPSHOT_CANDIDATES=80
COST_MAX_ROUNDTRIP_PCT=3.5
# patient = skip weak setups (save for accumulate) | fill_today = deploy remaining envelope before close
BUDGET_PACE=patient
SUPERVISOR_POLL_SEC=30
ENGINE_HEARTBEAT_MAX_SEC=90

# RL
RL_ACTIVE_VERSION=ppo_v1
RL_MODEL_DIR=/var/lib/bharatquant/models/rl
RL_OBSERVER_ENABLED=true
RL_AGENT_ENABLED=true
RL_TRAIN_ON_CLOSE=true
RL_TRAIN_ON_TRADE=true
RL_LEARNING_RATE=1e-5
RL_TRAIN_EPOCHS=2
RL_SB3_TIMESTEPS=2000
RL_MAX_TRANSITIONS_PER_TRAIN=800
RL_ABNORMAL_DAY_PCT=3.0
RL_ABNORMAL_LR_SCALE=0.3
RL_ABNORMAL_TIMESTEPS_SCALE=0.25
RL_SHADOW_LOOKBACK_DAYS=30
RL_SHADOW_MAX_SYMBOLS=12
RL_SHADOW_MAX_REGRESSION_PCT=2.0
POSTMARKET_RL_DEFER=true
PREMARKET_ROUTINE_TIME=8:45
POSTMARKET_ROUTINE_TIME=16:15
VIX_BUDGET_AUTO_APPROVE_MAX=22
LLM_BEARISH_VETO=-0.5
RL_USE_GUARDRAILS=true
FEED_STALE_SEC=5
TELEMETRY_LATENCY_WARN_MS=400
LIMIT_CHASE_ENABLED=false
LIMIT_CHASE_ATTEMPTS=3
LIMIT_CHASE_WAIT_SEC=1.5
RL_MIN_TRANSITIONS_VETO=80
RL_DRAWDOWN_PENALTY=0.5

SHADOW_MODE=false
MAX_SECTOR_PCT=40
VAR_LIMIT_PCT=3
# Hybrid brain + muscle (LLM macro bias + RL primary)
LLM_ENABLED=true
VERTEX_GEMINI_ENABLED=true
GCP_PROJECT=__GCP_PROJECT_ID__
VERTEX_LOCATION=us-central1
VERTEX_GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=__GEMINI_API_KEY__
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=__OPENAI_API_KEY__
ANTHROPIC_API_KEY=__ANTHROPIC_API_KEY__
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
LLM_MACRO_INTERVAL_SEC=3600
RL_PRIMARY_MODE=true
RL_PRIMARY_MIN_TRANSITIONS=200
RL_USE_SB3=true
RL_HOLD_DECAY_PER_MIN=0.00015
RL_LOSS_HOLD_PENALTY=0.002
MIN_ORDER_INTERVAL_SEC=30
MIS_SQUAREOFF_HOUR=15.167
RECONCILE_INTERVAL_SEC=300
RECONCILE_AUTO_REPAIR=true
MARGIN_MONITOR_SEC=60
MARGIN_UTIL_HALT_PCT=85
BROKER_SL_ENABLED=true
KITE_DEPTH_MODE=true
ATR_SIZING_ENABLED=true
ASYNC_LOGGING=true
